# Yerel geliştirme: Vite proxy /api → backend
VITE_API_URL=/api
VITE_DEV_API_PROXY=http://127.0.0.1:4000

# İsteğe bağlı: Cloudflare R2 public medya tabanı (tam https URL'ler aynen kullanılır)
# VITE_R2_PUBLIC_BASE_URL=https://cdn.example.com
# VITE_BACKEND_PUBLIC_URL=http://127.0.0.1:4000
# VITE_UPLOADS_BASE_URL=http://127.0.0.1:4000

# Production örnek:
# VITE_API_URL=https://woontegra.com/api
